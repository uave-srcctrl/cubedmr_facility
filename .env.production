# Production Environment Configuration
NODE_ENV=production

# Backend API Configuration
# Use your production domain here (with valid certificate)
BACKEND_API_URL=https://cubed-mr.app/get

# Express Server
PORT=5000
HOST=0.0.0.0

# Logging
LOG_FILE=/var/log/wounddatacenter/server-login.log

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=20
RATE_LIMIT_WINDOW_MS=900000
