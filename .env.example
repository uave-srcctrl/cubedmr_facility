# ==========================================
# Environment Configuration
# ==========================================

# Node environment (development | production)
NODE_ENV=production

# ==========================================
# Security - CRITICAL
# ==========================================

# JWT Secret - MUST be set in production
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Require HTTPS (set to false only for development)
# In production, this MUST be true or unset (defaults to true)
REQUIRE_HTTPS=true

# ==========================================
# Database Configuration (Future)
# ==========================================

# When migrating to persistent database:
# DATABASE_URL=postgresql://user:password@localhost:5432/facility
# DATABASE_USER=admin
# DATABASE_PASSWORD=secure_password

# ==========================================
# Application Configuration
# ==========================================

# Server port
PORT=5000

# Frontend base URL
VITE_BACKEND_URL=https://cubed-mr.app

# ==========================================
# Logging
# ==========================================

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# ==========================================
# Rate Limiting (Development)
# ==========================================

# Login rate limit attempts per 15 minutes
RATE_LIMIT_LOGIN_ATTEMPTS=20

# ==========================================
# HTTPS/TLS (Production)
# ==========================================

# Certificate and key files (when using Node directly)
# TLS_CERT=/etc/ssl/certs/server.crt
# TLS_KEY=/etc/ssl/private/server.key

# Timeout de peticiones en ms (usado por fetchWithTimeout en queryClient)
VITE_REQUEST_TIMEOUT=30000
